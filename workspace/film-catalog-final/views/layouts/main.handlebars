<!DOCTYPE html>
<html>
  <head lang="en">
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{title}}</title>
    <link rel='stylesheet' href='/bootstrap/css/bootstrap.css' />
  </head>
  <body data-bs-theme="dark">
    {{#if flash}}
      <div class="alert-dismissible fade show alert-{{flash.type}}" role="alert">
        <strong>{{flash.intro}}</strong> {{{flash.message}}}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {{/if}}
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">The Film Catalog</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
          <div class="navbar-nav me-auto">
            <a class="nav-link" href="/">About</a>
            <a class="nav-link" href="/films">Film Catalog</a>
          </div>
          <div class="d-flex">
            {{#if currentUser}}
              <span class="navbar-text me-3">Welcome, {{currentUser.name}}</span>
              <form action="/admin/logout" role="form" method="post" class="d-flex">
                <input type="hidden" name="_csrf" value="{{_csrfToken}}">
                <button class="btn btn-outline-light" type="submit">Logout</button>
              </form>
            {{else}}
              <a class="nav-link" href="/admin/login">Login</a>
            {{/if}}
          </div>
        </div>
      </div>
    </nav>
    <div class="container">
      {{{body}}}
    </div>
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
  </body>
</html>