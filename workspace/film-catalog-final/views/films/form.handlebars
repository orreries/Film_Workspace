<form action="/films/upsert" role="form" method="post">
  <input type="hidden" name="_csrf" value="{{_csrfToken}}">

  {{#if film}}
    <div>
        <h2>{{film.title}} ({{film.releaseYear}})</h2>
        <h3>{{film.director}}</h3>
        <p>{{film.description}}</p>
        <p>Analysis Status: {{film.isAnalyzed}}</p>
        <input type="hidden" name="id" value="{{film.id}}">
  </div>
  {{/if}}
    <div>
    <label for="title">Title</label>
    <input type="text" id="title" name="title" {{#if film}}value="{{film.title}}"{{/if}}>
  </div>
  <div>
    <label for="release_year">Release Year</label>
    <input type="text" id="release_year" name="releaseYear" {{#if film}}value="{{film.releaseYear}}"{{/if}}>
  </div>
  {{!-- using Claude for the in-progress dropdown menu code on the form --}}
  {{!-- it helped with the general formatting of the yes/no/in-progress analysis options --}}
<div>
  <label for="is_analyzed">Analysis Status</label>
  <select id="is_analyzed" name="isAnalyzed">
    <option value="no" {{#if film}}{{#if (eq film.isAnalyzed "no")}}selected{{/if}}{{/if}}>No</option>
    <option value="yes" {{#if film}}{{#if (eq film.isAnalyzed "yes")}}selected{{/if}}{{/if}}>Yes</option>
    <option value="in-progress" {{#if film}}{{#if (eq film.isAnalyzed "in-progress")}}selected{{/if}}{{/if}}>In Progress</option>
  </select>
</div>
<div>
    <label for="director">Director</label>
    <input type="text" id="director" name="director" {{#if film}}value="{{film.director}}"{{/if}}>
  </div>
<div>
  <label for="description">Description</label>
  <textarea rows="5" id="description" name="description">{{#if film}}{{film.description}}{{/if}}</textarea>
</div>
  <button type="submit" class="btn btn-primary">Submit</button>
</form>